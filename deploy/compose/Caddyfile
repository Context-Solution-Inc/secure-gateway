# Caddy reverse proxy: automatic HTTPS (Let's Encrypt) terminating TLS for the
# relay and auth services. reverse_proxy transparently handles WebSocket upgrades
# and sets X-Forwarded-For / X-Forwarded-Proto, so the upstreams run plain HTTP
# with RELAY_TRUST_PROXY=true / AUTH_TRUST_PROXY=true and see the real client IP.
{
	email {$ACME_EMAIL}
}

# Public wss endpoint -> relay.
{$RELAY_HOST} {
	# Never expose operational metrics on the public edge (SG-11). Metrics are
	# served on each service's private metrics listener (RELAY_METRICS_ADDR /
	# AUTH_METRICS_ADDR), scraped over the internal network only.
	@metrics path /metrics
	respond @metrics 404
	reverse_proxy relay:8443
}

# Public HTTPS API (login/pairing/JWKS/webhooks) -> auth.
{$AUTH_HOST} {
	@metrics path /metrics
	respond @metrics 404
	reverse_proxy auth:8080
}

# Public download media -> internal static server (static-web-server). Path-based
# categories map onto subdirs of the server root (e.g. /models/* -> /srv/models/*).
# Caddy terminates TLS and streams the response; the upstream serves plain HTTP with
# byte-range support so large downloads resume. NOTE: this serves anything under this
# host to anyone with the URL — gate it (forward_auth / signed URLs) before
# publishing private media.
{$DOWNLOADS_HOST} {
	reverse_proxy downloads:8080
}
