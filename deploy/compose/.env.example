# Production secrets/config for the single-VPS docker compose deployment.
# Copy to `.env` (same directory), fill in real values, and keep it off git
# (deploy/compose/.env is gitignored). Never bake these into an image.

# --- Public hostnames (DNS A records must point at this VPS) ---
RELAY_HOST=relay.example.com
AUTH_HOST=auth.example.com
ACME_EMAIL=ops@example.com        # Let's Encrypt account email (Caddy)

# --- JWT identity (relay and auth MUST share the issuer) ---
JWT_ISSUER=https://auth.example.com

# --- Datastore / backplane passwords (alphanumeric recommended) ---
POSTGRES_PASSWORD=CHANGE_ME_db
REDIS_PASSWORD=CHANGE_ME_redis

# --- Stripe (from the Stripe dashboard) ---
AUTH_STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
AUTH_STRIPE_SECRET_KEY=sk_live_CHANGE_ME      # enables nightly reconciliation

# --- Admin key gating POST /v1/accounts (empty disables the endpoint) ---
AUTH_ADMIN_KEY=CHANGE_ME_admin
