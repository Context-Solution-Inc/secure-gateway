# Production secrets/config for the single-VPS docker compose deployment.
# Copy to `.env` (same directory), fill in real values, and keep it off git
# (deploy/compose/.env is gitignored). Never bake these into an image.

# --- Public hostnames (DNS A records must point at this VPS) ---
RELAY_HOST=relay.example.com
AUTH_HOST=auth.example.com
DOWNLOADS_HOST=downloads.example.com  # download media, e.g. /models/* (static-web-server behind Caddy)
ACME_EMAIL=ops@example.com        # Let's Encrypt account email (Caddy)

# --- JWT identity (relay and auth MUST share the issuer) ---
JWT_ISSUER=https://auth.example.com

# --- Datastore / backplane passwords (alphanumeric recommended) ---
POSTGRES_PASSWORD=CHANGE_ME_db
REDIS_PASSWORD=CHANGE_ME_redis

# --- Stripe (from the Stripe dashboard) ---
# All-or-none: the three AUTH_STRIPE_* vars below enable billing TOGETHER, or
# leave ALL THREE empty and set AUTH_BILLING_DISABLED=true to run with secure
# links ungated. Any partial combination (e.g. dropping just AUTH_STRIPE_PRICE_ID)
# is rejected at startup so a typo can never silently disable subscription gating.
AUTH_STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME    # subscription webhooks
AUTH_STRIPE_SECRET_KEY=sk_live_CHANGE_ME      # nightly reconciliation + desktop checkout/portal
AUTH_STRIPE_PRICE_ID=price_CHANGE_ME          # desktop subscription plan; enables POST /v1/checkout/start

# Run WITHOUT Stripe: leave all three AUTH_STRIPE_* above empty and uncomment the
# line below. The gateway then auto-provisions an open license and does not gate
# secure links on a subscription. The desktop "upgrade" flow still works:
# /v1/checkout/start auto-creates the account and returns a claim_code instead of
# a Stripe URL. Only /v1/webhooks/stripe returns 503.
# AUTH_BILLING_DISABLED=true

# --- Desktop subscription onboarding (claim-token flow) ---
# AUTH_PUBLIC_URL is required when Stripe is enabled (the checkout success_url
# base). Also enable the Stripe Customer portal in the dashboard so
# POST /v1/billing-portal ("Subscription Settings") works.
AUTH_PUBLIC_URL=https://auth.example.com      # this service's public base URL
AUTH_CLAIM_TTL=30m                            # one-time checkout-claim lifetime

# --- Admin key gating POST /v1/accounts (empty disables the endpoint) ---
AUTH_ADMIN_KEY=CHANGE_ME_admin

# --- Image-based deploy only (docker-compose.prod-image.yml) ---
# Set these to pull prebuilt relay/auth images from a registry instead of
# building on the VPS. Ignored by docker-compose.prod.yml (which builds locally).
# Pin a real, immutable tag (or a @sha256 digest) — never :latest in prod.
IMAGE_REGISTRY=ghcr.io/context-solutions-inc/secure-gateway
IMAGE_TAG=1.0.0
