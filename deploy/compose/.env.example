# Production secrets/config for the single-VPS docker compose deployment.
# Copy to `.env` (same directory), fill in real values, and keep it off git
# (deploy/compose/.env is gitignored). Never bake these into an image.

# --- Public hostnames (DNS A records must point at this VPS) ---
RELAY_HOST=relay.example.com
AUTH_HOST=auth.example.com
ACME_EMAIL=ops@example.com        # Let's Encrypt account email (Caddy)

# --- JWT identity (relay and auth MUST share the issuer) ---
JWT_ISSUER=https://auth.example.com

# --- Datastore / backplane passwords (alphanumeric recommended) ---
POSTGRES_PASSWORD=CHANGE_ME_db
REDIS_PASSWORD=CHANGE_ME_redis

# --- Stripe (from the Stripe dashboard) ---
AUTH_STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
AUTH_STRIPE_SECRET_KEY=sk_live_CHANGE_ME      # nightly reconciliation + desktop checkout/portal

# --- Desktop subscription onboarding (claim-token flow; optional) ---
# Set AUTH_STRIPE_PRICE_ID to enable POST /v1/checkout/start (the desktop
# "Upgrade to anywhere connection" flow). Requires AUTH_STRIPE_SECRET_KEY and
# AUTH_PUBLIC_URL (the checkout success_url base). Also enable the Stripe Customer
# portal in the dashboard so POST /v1/billing-portal ("Subscription Settings")
# works. Leave AUTH_STRIPE_PRICE_ID empty to disable desktop checkout entirely.
AUTH_STRIPE_PRICE_ID=                         # e.g. price_CHANGE_ME (monthly plan)
AUTH_PUBLIC_URL=https://auth.example.com      # this service's public base URL
AUTH_CLAIM_TTL=30m                            # one-time checkout-claim lifetime

# --- Admin key gating POST /v1/accounts (empty disables the endpoint) ---
AUTH_ADMIN_KEY=CHANGE_ME_admin

# --- Image-based deploy only (docker-compose.prod-image.yml) ---
# Set these to pull prebuilt relay/auth images from a registry instead of
# building on the VPS. Ignored by docker-compose.prod.yml (which builds locally).
# Pin a real, immutable tag (or a @sha256 digest) — never :latest in prod.
IMAGE_REGISTRY=ghcr.io/lley154/secure-gateway
IMAGE_TAG=1.0.0
