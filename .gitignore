# Compiled binaries & signing keys (never commit)
/bin/
/keys/
*.pem
*.key.json

# Production compose secrets / signing keys (never commit)
/deploy/compose/.env
/deploy/compose/keys/

# Download media served for download (e.g. downloads/models/*) — large/provisioned
# on the host, keep the directory tracked (.gitkeep) but never commit the blobs.
/deploy/compose/downloads/**
!/deploy/compose/downloads/.gitkeep

# Local environment files (keep .env.example tracked)
.env
.env.*
!.env.example

# Go build / test artifacts
*.test
*.out

# JVM / Gradle SDK build artifacts (the gradle/ wrapper dir stays tracked)
.gradle/
build/

# Swift / iOS build artifacts
.build/

# OS / editor cruft
.DS_Store
.idea/
*.iml
.vscode/
